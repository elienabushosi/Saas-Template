# SaaS Template Backend – copy to .env.development and .env.production
# Backend loads .env.{NODE_ENV} (development or production)
# Leave placeholders to run locally without connecting services; replace with real values when ready.

# -----------------------------------------------------------------------------
# Supabase (create a project at supabase.com, then Settings → API)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder
SUPABASE_SERVICE_ROLE_KEY=placeholder

# -----------------------------------------------------------------------------
# Resend (email) – leave unset or empty until you connect; app will not send emails
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
RESEND_FROM_EMAIL=SaaS Template <onboarding@resend.dev>
ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Stripe – use test keys in dev; leave empty or placeholder until you connect
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# -----------------------------------------------------------------------------
# Server & frontend
# -----------------------------------------------------------------------------
PORT=3002
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Geo / external APIs – optional; leave placeholder if not using these features
# -----------------------------------------------------------------------------
GEOSERVICE_API_KEY=placeholder
