# SaaS Template Frontend – copy to .env.development and .env.production
# Next.js loads .env.development when NODE_ENV=development, .env.production when NODE_ENV=production
# Leave placeholders to run locally without connecting services; replace when ready.

# -----------------------------------------------------------------------------
# API (backend URL)
# -----------------------------------------------------------------------------
# Development: local backend
NEXT_PUBLIC_API_URL=http://localhost:3002
# Production: set to your deployed backend (e.g. Railway)
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# -----------------------------------------------------------------------------
# Google Maps – optional; leave empty or placeholder if not using address autocomplete
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=placeholder

# -----------------------------------------------------------------------------
# Stripe – product/price IDs (for checkout, upgrade, billing)
# Use test IDs in .env.development; set live IDs in .env.production when going live.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PRODUCT_ID=placeholder
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=placeholder
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=placeholder
